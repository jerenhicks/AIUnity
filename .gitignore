# =============================================================================
# Unity generated folders
# =============================================================================
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset meta files should be tracked alongside their assets
!/[Aa]ssets/**/*.meta

# Autogenerated Jetbrains Rider plugin
[Aa]ssets/Plugins/Editor/JetBrains*

# =============================================================================
# IDE / Editor files
# =============================================================================
.vs/
.vscode/
.idea/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files for IDE artifacts
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# =============================================================================
# Builds
# =============================================================================
*.apk
*.aab
*.unitypackage
*.app
*.exe
*.x86_64
*.x86
*.dmg

# =============================================================================
# Crashlytics
# =============================================================================
crashlytics-build.properties

# =============================================================================
# Addressables
# =============================================================================
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# =============================================================================
# Temporary auto-generated Android Assets
# =============================================================================
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# =============================================================================
# Operating system files
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Logs & tooling
# =============================================================================
node_modules/
*.log

# =============================================================================
# Project-specific
# =============================================================================
# Secrets: never commit the real LLM config (keep the .example committed)
llm.config.json
# Agents' runtime context files
AgentMemory/
